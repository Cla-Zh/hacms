{
  "id": "2026-06-22-initial-prompt-spec",
  "date": "2026-06-22",
  "trigger": "initial_creation",
  "summary": "机构级全球投资情报系统 Ultimate Edition, 16 模块 + 11 引擎 + 5 CIO 投资委员会, hacms 浅色主题",
  "core_mission": {
    "role": "机构级全球投资情报系统",
    "not_role": "不是新闻摘要生成器",
    "primary_questions": [
      "资金在哪里流动?",
      "为什么流动?",
      "未来会流向哪里?"
    ],
    "asset_evaluation": [
      "哪些资产被低估?",
      "哪些资产被高估?"
    ],
    "trend_classification": [
      "哪些趋势是短期炒作?",
      "哪些趋势是未来 5 年的核心机会?"
    ],
    "outputs": [
      "短期交易策略",
      "中期配置策略",
      "长期资产配置策略"
    ]
  },
  "targets": [
    "短期交易策略",
    "中期配置策略",
    "长期资产配置策略"
  ],
  "engines": {
    "market_regime": {
      "name": "Market Regime Engine",
      "purpose": "判断当前市场环境",
      "states": [
        "经济复苏期",
        "经济过热期",
        "滞胀期",
        "衰退期",
        "风险偏好提升期",
        "风险偏好下降期",
        "AI超级周期",
        "科技牛市",
        "能源牛市",
        "防御市场"
      ],
      "outputs": ["confidence_score", "historical_reference", "start_date", "expected_duration"]
    },
    "global_liquidity": {
      "name": "Global Liquidity Engine",
      "purpose": "分析全球流动性",
      "data_sources": [
        "美联储资产负债表",
        "逆回购 (RRP)",
        "国债发行",
        "货币供应量 (M2)",
        "全球央行流动性",
        "财政部 TGA"
      ],
      "states": ["流动性扩张", "流动性收缩", "流动性拐点"]
    },
    "smart_money": {
      "name": "Smart Money Engine",
      "purpose": "识别聪明资金行为",
      "actors": ["机构资金", "对冲基金", "养老基金", "主权基金", "大型ETF"],
      "outputs": ["增持方向", "减持方向"]
    },
    "etf_flow": {
      "name": "ETF Flow Engine",
      "purpose": "监控 ETF 资金流向",
      "tracked_etfs_us": ["SPY", "QQQ", "IWM", "SOXX", "SMH", "ARKK", "KWEB"],
      "tracked_etfs_cn": ["510300 (沪深300)", "588000 (科创50)", "159915 (创业板)"],
      "tracked_etfs_hk": ["513180 (恒生科技)"],
      "tracked_etfs_commodity": ["GLD"],
      "metrics": ["净流入", "净流出", "AUM", "YTD", "持续性"]
    },
    "options_flow": {
      "name": "Options Flow Engine",
      "purpose": "监控期权异动",
      "monitors": ["异常期权成交", "大额 Call", "大额 Put", "Gamma 变化"],
      "outputs": ["机构押注方向", "市场预期波动率"]
    },
    "sector_rotation": {
      "name": "Sector Rotation Engine",
      "purpose": "分析行业轮动",
      "windows": ["1天", "7天", "30天", "90天"],
      "outputs": ["轮动路径", "轮动速度", "轮动概率"]
    },
    "valuation": {
      "name": "Valuation Engine",
      "purpose": "跨市场估值对比",
      "metrics": ["PE", "PB", "PS", "PEG", "DCF", "自由现金流", "Z-Score"],
      "categories": ["严重低估", "低估", "合理", "高估", "泡沫"]
    },
    "earnings": {
      "name": "Earnings Engine",
      "purpose": "财报分析",
      "monitors": ["超预期", "低于预期", "业绩指引变化", "利润率变化", "增长质量变化"]
    },
    "insider_tracking": {
      "name": "Insider Tracking Engine",
      "purpose": "内部人交易监控",
      "monitors": ["CEO 增持", "CEO 减持", "高管交易", "机构大额交易 (13F)"],
      "outputs": ["高可信度信号"]
    },
    "black_swan": {
      "name": "Black Swan Engine",
      "purpose": "黑天鹅预警",
      "categories": [
        "战争", "地缘冲突", "金融危机",
        "房地产危机", "银行风险", "债务风险", "主权违约",
        "极端天气", "重大技术突破"
      ],
      "outputs": ["发生概率", "影响等级", "持续时间"]
    },
    "ai_debate": {
      "name": "AI Debate Engine",
      "purpose": "Bull/Bear 独立辩论",
      "agents": {
        "bull": "论证为什么上涨, 为什么值得投资",
        "bear": "论证为什么下跌, 为什么存在风险",
        "committee": "Investment Committee Agent 进行裁决"
      }
    }
  },
  "committee": {
    "name": "Investment Committee",
    "members": [
      {"role": "Macro CIO", "responsibility": "宏观经济 (利率 / 通胀 / 增长)"},
      {"role": "Equity CIO", "responsibility": "权益市场 (行业 / 个股 / 估值)"},
      {"role": "Quant CIO", "responsibility": "量化 (因子 / 动量 / 套利)"},
      {"role": "Risk CIO", "responsibility": "风险管理 (VaR / 集中度 / 流动性)"},
      {"role": "Policy CIO", "responsibility": "政策面 (央行 / 财政 / 监管)"}
    ],
    "voting_mechanism": {
      "5_bull": "强烈看多",
      "3_4_bull": "谨慎看多",
      "2_3_neutral": "中性",
      "3_4_bear": "谨慎看空",
      "5_bear": "强烈看空"
    },
    "outputs": ["投票结果", "综合评分 0-100"]
  },
  "trend_grades": {
    "S": {"label": "超级趋势", "time_horizon": "未来 5 年以上"},
    "A": {"label": "中期趋势", "time_horizon": "未来 1-3 年"},
    "B": {"label": "短中期趋势", "time_horizon": "未来 6-12 个月"},
    "C": {"label": "短期热点", "time_horizon": "1-3 个月"},
    "D": {"label": "噪音", "time_horizon": "< 1 个月"}
  },
  "scoring_weights": {
    "资金流": 20,
    "趋势": 20,
    "估值": 20,
    "政策": 10,
    "业绩": 10,
    "市场情绪": 10,
    "风险": 10
  },
  "scoring_buckets": [
    {"range": "80-100", "label": "强烈推荐"},
    {"range": "60-79", "label": "推荐"},
    {"range": "40-59", "label": "中性"},
    {"range": "20-39", "label": "谨慎"},
    {"range": "0-19", "label": "回避"}
  ],
  "dashboard_modules": [
    {"id": 1, "name": "全球市场状态中心", "scope": ["市场环境", "流动性状态", "风险偏好"]},
    {"id": 2, "name": "全球资产热力图", "scope": ["股票", "债券", "黄金", "商品", "外汇", "数字货币"]},
    {"id": 3, "name": "全球资金流向地图", "scope": ["国家维度", "行业维度", "资产维度"]},
    {"id": 4, "name": "行业轮动仪表盘", "scope": ["7天", "30天", "90天"]},
    {"id": 5, "name": "聪明资金追踪", "scope": ["机构资金", "主权基金", "对冲基金"]},
    {"id": 6, "name": "期权异动监控", "scope": ["大单", "Gamma"]},
    {"id": 7, "name": "黑天鹅预警中心", "scope": ["概率", "影响等级"]},
    {"id": 8, "name": "市场叙事排行榜", "scope": ["Top 20 Narrative"]},
    {"id": 9, "name": "A 股机会池", "scope": ["沪深300", "科创50", "创业板"]},
    {"id": 10, "name": "港股机会池", "scope": ["恒生科技", "港股通"]},
    {"id": 11, "name": "美股机会池", "scope": ["SPX", "NDX", "RUT"]},
    {"id": 12, "name": "ETF 机会池", "scope": ["跨市场 ETF"]},
    {"id": 13, "name": "长期主题投资", "scope": ["1年", "3年", "5年"]},
    {"id": 14, "name": "AI 投资委员会结论", "scope": ["5 CIO 投票", "综合评分"]},
    {"id": 15, "name": "90 天时间轴", "scope": ["日期", "风险评分", "重大事件"]},
    {"id": 16, "name": "历史趋势演化", "scope": ["7天", "30天", "90天", "180天", "365天"]}
  ],
  "ui_style": {
    "theme": "light_hacms",
    "style_fusion": ["Bloomberg Terminal", "TradingView", "Apple", "Linear"],
    "goals": ["专业", "现代", "清晰", "高信息密度", "不杂乱"],
    "current_implementation": {
      "background": "#fafbfc",
      "primary_color": "#0066ff",
      "bull_color": "#10b981",
      "bear_color": "#ef4444",
      "neutral_color": "#f59e0b",
      "purple_color": "#8b5cf6",
      "font_family": "system-ui, SF Pro Display, PingFang SC",
      "responsive": ["桌面", "平板", "手机"]
    },
    "history": [
      {"date": "2026-06-22", "theme": "dark_bloomberg", "description": "初始版本, Bloomberg 暗色 (深空黑 + 翠绿)"},
      {"date": "2026-06-22", "theme": "light_hacms", "description": "改为 hacms 浅色 (浅灰 + 主蓝), 跟主页统一"}
    ]
  },
  "architecture_decisions": {
    "directory_isolation": "content/markets/ 独立目录, 不污染 articles",
    "integration_method": "iframe 嵌入, 不改主页 SPA 路由",
    "tab_design": "主页 sidebar 加第 3 个 Tab, 与调研/智慧问答同级",
    "routing": "#markets 哈希触发切换",
    "iframe_src": "content/markets/index.html (相对路径, 适配根目录 + 子目录)",
    "css_strategy": "色板变量驱动 (:root), 改主题只改变量",
    "data_strategy": "JSON 化 (22 顶级键), JS 读取渲染, 便于以后接真实 API",
    "module_count": 16,
    "engine_count": 11
  },
  "current_state": {
    "regime": "风险偏好下降期",
    "regime_confidence": 72,
    "liquidity": "收缩",
    "liquidity_confidence": 78,
    "committee_verdict": "谨慎看多",
    "committee_score": 58
  },
  "change_log": [
    "第 1 次创建 markets 功能域",
    "11 引擎完整定义 (市场环境/流动性/聪明资金/ETF/期权/轮动/估值/财报/内部人/黑天鹅/AI辩论)",
    "5 CIO 投资委员会机制",
    "16 模块仪表盘",
    "S/A/B/C/D 5 级趋势分级",
    "7 维度评分权重 (资金流 20% / 趋势 20% / 估值 20% / 政策 10% / 业绩 10% / 情绪 10% / 风险 10%)",
    "浅色 hacms 主题 (从暗色 Bloomberg 改)",
    "iframe 相对路径修复",
    "sidebar 标签云字号缩小 (防止溢出)"
  ]
}