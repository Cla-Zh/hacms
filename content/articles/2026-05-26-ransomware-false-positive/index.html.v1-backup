.tooltip{position:relative;border-bottom:1px dashed var(--accent);color:var(--accent-dark);cursor:help;font-weight:500}
.tooltip::after,.tooltip::before{position:absolute;left:50%;opacity:0;pointer-events:none;transition:opacity .2s ease,transform .2s ease;z-index:99}
.tooltip::after{content:attr(data-tip);bottom:calc(100% + 8px);transform:translateX(-50%) translateY(4px);background:#1a1a1a;color:#fff;padding:10px 14px;border-radius:6px;font-size:12.5px;font-weight:400;line-height:1.55;width:max-content;max-width:360px;min-width:140px;box-shadow:0 6px 20px rgba(0,0,0,.25);text-align:left;white-space:normal;letter-spacing:0}
.tooltip::before{content:'';bottom:100%;transform:translateX(-50%) translateY(4px);border:6px solid transparent;border-top-color:#1a1a1a}
.tooltip:hover::after,.tooltip:focus::after{opacity:1;transform:translateX(-50%) translateY(0)}
.tooltip:hover::before,.tooltip:focus::before{opacity:1;transform:translateX(-50%) translateY(0)}

/* Inline citation */
