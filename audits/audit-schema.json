{
  "schema_version": "1.0",
  "field_definitions": {
    "audit_id": "唯一审计 ID (e.g. 2026-06-18-data-security-future-insights-r1)",
    "article_id": "文章 ID (e.g. 2026-06-18-data-security-future-insights)",
    "round": "第 N 轮 (从 1 开始)",
    "timestamp": "审计时间 ISO 8601",
    "agent": "审查 Agent ID",
    "method": "使用的审查方法 (e.g. web_search, web_extract, manual_review)",
    "total_checks": "总检查点数",
    "issues_found": "本轮发现的问题数",
    "issues_fixed": "本轮已修正数",
    "issues_remaining": "遗留待复检数",
    "issues": [
      {
        "id": "issue-1",
        "severity": "critical|high|medium|low",
        "type": "fabrication|outdated|internal_inconsistency|citation|computation|grammar",
        "location": "具体位置 (e.g. sec-3/p2/table-2)",
        "original": "原文",
        "issue": "问题描述",
        "source": "权威来源 (URL / 论文 ID / 文档)",
        "fix": "修正方案 (如果已修)",
        "fix_status": "fixed|deferred|false_positive",
        "fix_timestamp": "修正时间"
      }
    ],
    "verification_sources": [
      "实际访问并验证的 URL / arXiv ID / DOI 列表"
    ],
    "stop_condition": "是否本轮达到终止条件 (连续 2 轮无新问题)",
    "next_round": "是否需要下一轮 (true|false)"
  }
}